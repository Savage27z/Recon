# HashKey Chain testnet
RPC_URL=https://testnet.hsk.xyz
CHAIN_ID=133

# Comma-separated ERC20 token addresses to watch.
TOKENS=0x42d77Bb3aeC7C1f4df2ffc9Cce3e5C3F5Ec39D65

# The merchant's receiving address — only inbound Transfer events to this
# address get logged as payments.
RECEIVING_ADDRESS=0xB155A22500C7893AF0c7FA0AB6e28d565C4fE1aA

# On-chain InvoiceRegistry — watcher mirrors InvoiceCreated + InvoicePaid events.
INVOICE_REGISTRY=0x55Ec99E2F0fd1EcF3Ee20689fE21eD6bb0cD1235

# Start block if the cursor table is empty. Use the earliest deploy block
# among the tokens you're watching so no payments are missed.
START_BLOCK=30098615

# Poll cadence in milliseconds.
POLL_INTERVAL_MS=10000

# Max blocks per getLogs call — HashKey's RPC caps this. 1000 is safe.
MAX_BLOCK_RANGE=1000

# SQLite path (relative to watcher/).
DB_PATH=./data/recon.db

# --- Tier 3 (LLM fuzzy matcher; OpenAI-compatible) ---
# Point at any OpenAI-compatible endpoint (BTL/DeepSeek, OpenAI, Together, etc.).
# Leave TIER3_ENABLED=false to disable even if the key is present.
TIER3_ENABLED=true
TIER3_API_KEY=
TIER3_BASE_URL=https://api.badtheorylabs.com/v1
TIER3_MODEL=deepseek-v4-flash
TIER3_MIN_CONFIDENCE=0.7
# Candidate invoices must have amount within this % of the payment.
TIER3_TOLERANCE_PCT=5
# Cap LLM calls per tick to bound cost.
TIER3_MAX_PER_TICK=10

# --- Webhook dispatch on match ---
# Destination URL + secret are per-merchant now (set from the dashboard
# Settings page, stored in the merchant_settings table) — a merchant with
# none configured is simply skipped, no retry burned. These vars only tune
# the shared delivery policy. The watcher signs each POST with an
# HMAC-SHA256 header: X-Recon-Signature: t=<unix-ts>,v1=<hex-hmac>
# HMAC input is `<unix-ts>.<raw-body>` — same shape as Stripe.
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_PER_TICK=10
